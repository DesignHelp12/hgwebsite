---
import '../styles/global.css'

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Hyssop Games — Addictive fun, reimagined',
	description = 'Hyssop Games is an indie studio crafting casual, addictive games with fresh new mechanics. Something fun is on the way — stay tuned.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" href="/favicon.ico" sizes="any" />
		<link rel="icon" type="image/png" sizes="32x32" href="/images/favicon-32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/images/favicon-16.png" />
		<link rel="apple-touch-icon" href="/images/apple-touch-icon.png" />
		<meta name="generator" content={Astro.generator} />
		<meta name="theme-color" content="#fbf2e3" />

		<title>{title}</title>
		<meta name="description" content={description} />

		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content="/images/logo.png" />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content="/images/logo.png" />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Poppins:wght@600;700;800;900&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body class="bg-ink text-white antialiased">
		<slot />

		<script src="https://f.convertkit.com/ckjs/ck.5.js" async></script>
	</body>
</html>